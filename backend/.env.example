# ============================================================
# backend/.env.example  — คัดลอกไปเป็น .env แล้วแก้ค่าตามจริง
# ============================================================

# Server
PORT=5000
NODE_ENV=development

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=""
DB_NAME=nutrisite_db

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_key_minimum_32_chars
JWT_EXPIRES=8h

# CORS — URL ของ Frontend
CLIENT_URL=http://localhost:5173
